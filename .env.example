# App — REQUIRED in production for sitemap, canonical URLs, Open Graph, and RSS
# Use your live domain (must match Google Search Console property)
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API
NEXT_PUBLIC_API_URL=/api

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=instagram_downloader

# Analytics (dashboard API protection)
ANALYTICS_API_KEY=your-secret-analytics-key

# Instagram extraction
# Set to true to disable real extraction and use placeholder responses
INSTAGRAM_USE_PLACEHOLDER_EXTRACTOR=false
# Optional override if Instagram changes their GraphQL doc id
INSTAGRAM_GRAPHQL_DOC_ID=24368985919464652

# Google AdSense
NEXT_PUBLIC_GOOGLE_ADSENSE_ENABLED=false
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
# Optional: used for /ads.txt (numeric part only, without ca-pub- prefix)
GOOGLE_ADSENSE_PUBLISHER_ID=xxxxxxxxxxxxxxxx

# Shared ad slots (create these in your AdSense dashboard)
NEXT_PUBLIC_ADS_SLOT_DISPLAY=0000000000
NEXT_PUBLIC_ADS_SLOT_HORIZONTAL=0000000000
NEXT_PUBLIC_ADS_SLOT_IN_ARTICLE=0000000000
NEXT_PUBLIC_ADS_SLOT_IN_FEED=0000000000
NEXT_PUBLIC_ADS_SLOT_SIDEBAR=0000000000

# Optional per-placement overrides
# NEXT_PUBLIC_ADS_SLOT_GLOBAL_TOP=
# NEXT_PUBLIC_ADS_SLOT_GLOBAL_BOTTOM=
# NEXT_PUBLIC_ADS_SLOT_HOME_HERO=
# NEXT_PUBLIC_ADS_SLOT_HOME_SECTIONS=
# NEXT_PUBLIC_ADS_SLOT_HOME_LEFT=
# NEXT_PUBLIC_ADS_SLOT_HOME_RIGHT=
# NEXT_PUBLIC_ADS_SLOT_HOME_LEFT_SECONDARY=
# NEXT_PUBLIC_ADS_SLOT_HOME_RIGHT_SECONDARY=
# NEXT_PUBLIC_ADS_SLOT_DOWNLOADER_TOP=
# NEXT_PUBLIC_ADS_SLOT_DOWNLOADER_BOTTOM=
# NEXT_PUBLIC_ADS_SLOT_DOWNLOAD_RESULT=
# NEXT_PUBLIC_ADS_SLOT_DOWNLOAD_POPUP=
# NEXT_PUBLIC_ADS_SLOT_BLOG_LIST=
# NEXT_PUBLIC_ADS_SLOT_BLOG_POST=
# NEXT_PUBLIC_ADS_SLOT_FAQ=
